  author = {Barile, Dimas Alejandro and Navarro Diaz, Gonzalo Pablo and Sosa, R and Otero, Ad},
  year = {2023},
  month = may,
  journal = {Journal of Physics: Conference Series},
  volume = {2505},
  number = {1},
